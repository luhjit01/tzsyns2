-- FIX:  Remove drag restrictions AFTER window is created
-- This avoids breaking the library's initialization
pcall(function()
    -- Find the actual GUI frame and remove all drag constraints
    local function RemoveDragLimits()
        -- Try to find the main frame
        local frame = nil
        for _,  v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v,  "Name") == "Poop" then
                frame = v
                break
            end
        end
        
        if frame then
            -- Remove all position clamping
            if rawget(frame,  "DragMaxX") then rawset(frame,  "DragMaxX",  999999) end
            if rawget(frame,  "DragMaxY") then rawset(frame,  "DragMaxY",  999999) end
            if rawget(frame,  "DragMinX") then rawset(frame,  "DragMinX",  -999999) end
            if rawget(frame,  "DragMinY") then rawset(frame,  "DragMinY",  -999999) end
            
            -- Also try to find and remove any clamp functions
            for _,  v in pairs(getgc(true)) do
                if type(v) == "table" then
                    if rawget(v,  "ClampPosition") then
                        rawset(v,  "ClampPosition",  function(pos) return pos end)
                    end
                    if rawget(v,  "UpdateDrag") then
                        -- Override to prevent clamping
                        rawset(v,  "UpdateDrag",  function() end)
                    end
                end
            end
            
            -- If frame has a Position property,  allow it to go anywhere
            if frame: IsA("Frame") then
                frame: GetPropertyChangedSignal("Position"): Connect(function()
                    -- Allow any position without restrictions
                end)
            end
        end
    end
    
    -- Run after a small delay to ensure the window is fully initialized
    task.wait(0.1)
    RemoveDragLimits()
end)

