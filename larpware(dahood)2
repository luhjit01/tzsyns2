        guiVisible = not guiVisible
        
        -- Toggle using the Frame property (works with PoopLibrary)
        if Window and Window.Frame then
            Window.Frame.Visible = guiVisible
        end
        
        -- Small delay to prevent spam
        task.wait(0.2)
        toggleCooldown = false
    end
    
    -- Camlock Hotkey
    if CamLockSettings.Enabled and input.KeyCode == CamLockSettings.Hotkey and not gameProcessed then
        if CamLockSettings.CurrentTarget then
            CamLockSettings.CurrentTarget = nil
        else
            CamLockSettings.CurrentTarget = getClosestPlayerToMouse()
        end
    end
end)

-- // Additional drag fix - run after GUI is fully loaded
task.spawn(function()
    task.wait(0.5) -- Wait for GUI to fully initialize
    
    pcall(function()
        -- Find the frame and remove all drag restrictions
        local function FindAndFixFrame()
            for _,  v in pairs(getgc(true)) do
                if type(v) == "table" and rawget(v,  "Name") == "Poop" then
                    -- Remove all drag limits
                    if rawget(v,  "DragMaxX") then rawset(v,  "DragMaxX",  999999) end
                    if rawget(v,  "DragMaxY") then rawset(v,  "DragMaxY",  999999) end
                    if rawget(v,  "DragMinX") then rawset(v,  "DragMinX",  -999999) end
                    if rawget(v,  "DragMinY") then rawset(v,  "DragMinY",  -999999) end
                    
                    -- Also remove any clamp functions
                    for _,  child in pairs(getgc(true)) do
                        if type(child) == "table" then
                            if rawget(child,  "ClampPosition") then
                                rawset(child,  "ClampPosition",  function(pos) return pos end)
                            end
                        end
                    end
                    
                    return true
                end
            end
            return false
        end
        
        FindAndFixFrame()
        
        -- Try multiple times to catch when the frame is created
        for i = 1,  10 do
            if FindAndFixFrame() then break end
            task.wait(0.1)
        end
    end)
end)

-- // Silent Aim Render Loop
RunService.RenderStepped: Connect(function()
    if SilentAimSettings.Enabled then
        if SilentAimSettings.ShowSilentAimTarget then
            if getClosestPlayer() then
                local Root = getClosestPlayer().Parent.PrimaryPart or getClosestPlayer()
                local RootToViewportPoint,  IsOnScreen = Camera: WorldToViewportPoint(Root.Position)
                mouse_box.Visible = IsOnScreen
                mouse_box.Position = Vector2.new(RootToViewportPoint.X,  RootToViewportPoint.Y)
            else
                mouse_box.Visible = false
                mouse_box.Position = Vector2.new()
            end
        end
        
        if SilentAimSettings.FOVVisible then
            fov_circle.Visible = true
            fov_circle.Position = getMousePosition()
        end
    else
        mouse_box.Visible = false
        fov_circle.Visible = false
    end
    
    -- Camlock Logic
    if CamLockSettings.Enabled and CamLockSettings.CurrentTarget and CamLockSettings.CurrentTarget.Character then
        local targetHead = CamLockSettings.CurrentTarget.Character: FindFirstChild("Head")
        if targetHead then
            local targetPosition = targetHead.Position
            
            if CamLockSettings.Prediction then
                local deltaTime = 0.1
                targetPosition = predictPosition(targetHead,  deltaTime)
            end
            
            Camera.CFrame = CFrame.new(Camera.CFrame.Position,  targetPosition)
        else
            CamLockSettings.CurrentTarget = nil
        end
    end
    
    -- Fly Logic
    if MiscSettings.FlyEnabled and RootPart and Character then
        local BV = RootPart: FindFirstChild("ClientFlight")
        if BV then
            local speed = 50
            local moveDirection = Vector3.new()
            
            if UserInputService: IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + Camera.CFrame.LookVector
            end
            if UserInputService: IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - Camera.CFrame.LookVector
            end
            if UserInputService: IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - Camera.CFrame.RightVector
            end
            if UserInputService: IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + Camera.CFrame.RightVector
            end
            if UserInputService: IsKeyDown(Enum.KeyCode.Space) then
                moveDirection = moveDirection + Vector3.new(0,  1,  0)
            end
            if UserInputService: IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDirection = moveDirection - Vector3.new(0,  1,  0)
            end
            
            if moveDirection.Magnitude > 0 then
                moveDirection = moveDirection.Unit * speed
            else
                moveDirection = Vector3.new(0,  0,  0)
            end
            
            BV.Velocity = moveDirection
        end
    end
    
    -- NoClip Logic
    if MiscSettings.NoClipEnabled and Character then
        for _,  child in pairs(Character: GetDescendants()) do
            if child: IsA("BasePart") then
                child.CanCollide = false
            end
        end
    end
end)

